pipeline {
    agent any

    environment {
        REGISTRY = "${params.LOCAL_REGISTRY ?: 'localhost:5000'}"
    }

    parameters {
        string(name: 'LOCAL_REGISTRY', defaultValue: 'localhost:5000', description: 'Local Docker registry host:port')
    }

    stages {
        stage('Unit Tests') {
            parallel {
                stage('Backend UT') {
                    steps {
                        dir('backend') {
                            sh 'go test -v ./...'
                        }
                    }
                }
                stage('Frontend UT') {
                    steps {
                        dir('frontend') {
                            sh 'CI=true npm test -- --watchAll=false --passWithNoTests'
                        }
                    }
                }
            }
        }

        stage('Lint') {
            parallel {
                stage('Backend Lint') {
                    steps {
                        dir('backend') {
                            sh 'go vet ./...'
                        }
                    }
                }
                stage('Frontend Lint') {
                    steps {
                        dir('frontend') {
                            sh 'npm run lint'
                        }
                    }
                }
            }
        }

        stage('Build') {
            parallel {
                stage('Backend Build') {
                    steps {
                        dir('backend') {
                            sh 'CGO_ENABLED=0 go build -o server .'
                        }
                    }
                }
                stage('Frontend Build') {
                    steps {
                        dir('frontend') {
                            sh 'npm ci'
                            sh 'npm run build'
                        }
                    }
                }
            }
        }

        stage('Package') {
            steps {
                script {
                    def timestamp = sh(script: "date +%Y%m%d-%H%M%S", returnStdout: true).trim()
                    env.PACKAGE_VERSION = timestamp
                }
                sh 'mkdir -p dist'
                dir('frontend') {
                    sh "npm pack --pack-destination ${WORKSPACE}/dist"
                }
                dir('backend') {
                    sh "tar -czvf ${WORKSPACE}/dist/backend-${env.PACKAGE_VERSION}.tar.gz server"
                }
                archiveArtifacts artifacts: 'dist/**', fingerprint: true
            }
        }

        stage('Dockerization') {
            parallel {
                stage('Docker Build - Frontend') {
                    steps {
                        dir('frontend') {
                            sh "docker build -t frontend:${env.PACKAGE_VERSION} -t frontend:latest ."
                        }
                    }
                }
                stage('Docker Build - Backend') {
                    steps {
                        dir('backend') {
                            sh "docker build -t backend:${env.PACKAGE_VERSION} -t backend:latest ."
                        }
                    }
                }
            }
        }

        stage('Push to Local Registry') {
            steps {
                script {
                    def version = env.PACKAGE_VERSION ?: 'latest'
                    sh """
                        docker tag frontend:${version} ${REGISTRY}/frontend:${version}
                        docker tag frontend:latest ${REGISTRY}/frontend:latest
                        docker tag backend:${version} ${REGISTRY}/backend:${version}
                        docker tag backend:latest ${REGISTRY}/backend:latest
                    """
                    // Add Jenkins credential ID 'local-registry-credentials' for auth; for insecure registry use dummy user/pass
                    withCredentials([usernamePassword(credentialsId: 'local-registry-credentials', usernameVariable: 'REG_USER', passwordVariable: 'REG_PASS')]) {
                        sh "echo \$REG_PASS | docker login -u \$REG_USER --password-stdin ${REGISTRY}"
                    }
                    sh """
                        docker push ${REGISTRY}/frontend:${version}
                        docker push ${REGISTRY}/frontend:latest
                        docker push ${REGISTRY}/backend:${version}
                        docker push ${REGISTRY}/backend:latest
                    """
                }
            }
        }
    }

    post {
        always {
            cleanWs(deleteDirs: true, patterns: [[pattern: 'node_modules', type: 'INCLUDE']])
        }
        failure {
            echo 'Pipeline failed. Check stages above.'
        }
        success {
            echo "Images pushed to ${REGISTRY}. Version: ${env.PACKAGE_VERSION}"
        }
    }
}
